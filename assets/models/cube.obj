# Cube centered at origin, proper UV layout per face

g cube

# Vertices
v -0.5 -0.5 -0.5
v -0.5  0.5 -0.5
v  0.5  0.5 -0.5
v  0.5 -0.5 -0.5
v -0.5 -0.5  0.5
v -0.5  0.5  0.5
v  0.5  0.5  0.5
v  0.5 -0.5  0.5

# UVs — simple quad layout, each face maps the full [0,1] range
vt 0.0 1.0
vt 1.0 1.0
vt 1.0 0.0
vt 0.0 0.0

# Normals
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0

# Faces (v/vt/vn) — each face maps all 4 UV corners
# Face 1: right (+X) cghd
f 3/1/1 7/2/1 8/3/1
f 3/1/1 8/3/1 4/4/1

# Face 2: left (-X) aefb
f 1/2/2 5/1/2 6/4/2
f 1/2/2 6/4/2 2/3/2

# Face 3: top (+Y) gcbf
f 7/1/3 3/2/3 2/3/3
f 7/1/3 2/3/3 6/4/3

# Face 4: bottom (-Y) dhea
f 4/4/4 8/1/4 5/2/4
f 4/4/4 5/2/4 1/3/4

# Face 5: front (+Z) hgfe
f 8/4/5 7/1/5 6/2/5
f 8/4/5 6/2/5 5/3/5

# Face 6: back (-Z) cdab
f 3/2/6 4/3/6 1/4/6
f 3/2/6 1/4/6 2/1/6